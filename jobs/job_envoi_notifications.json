{
  "name": "bl-v3-envoi-notifications",
  "description": "Envoi des notifications de la solution BL dématérialisés (passages EDI NOK -> OK) vers Teams (webhook entrant) et/ou un flux Power Automate HTTP (email Outlook...). Marque envoyee = true uniquement après réussite de tous les canaux configurés.",
  "tasks": [
    {
      "task_key": "envoi_notifications",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/<VOTRE_EMAIL>/bl_v3/notebook_envoi_notifications",
        "source": "WORKSPACE"
      },
      "environment_key": "bl_env"
    }
  ],
  "environments": [
    {
      "environment_key": "bl_env",
      "spec": {
        "client": "4",
        "dependencies": ["psycopg[binary]==3.2.3", "databricks-sdk>=0.81.0"]
      }
    }
  ],
  "parameters": [
    { "name": "pg_host", "default": "<PGHOST_DU_PROJET_LAKEBASE_V3>" },
    { "name": "pg_database", "default": "databricks_postgres" },
    { "name": "pg_schema", "default": "bl_demat" },
    { "name": "lakebase_endpoint", "default": "" },
    { "name": "teams_webhook_url", "default": "" },
    { "name": "power_automate_url", "default": "" },
    { "name": "lot_max", "default": "100" }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 * * * ?",
    "timezone_id": "Europe/Paris",
    "pause_status": "UNPAUSED"
  },
  "email_notifications": {
    "on_failure": ["younes.elhachi@gmail.com"]
  },
  "max_concurrent_runs": 1
}
